# =============================================
# RAG System — Variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores
# =============================================

# --- PostgreSQL ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=

# --- LLM (via LiteLLM) ---
# Pega sua key em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Pra trocar de provider depois, basta mudar essas strings e setar
# a key do novo provider acima. Ex.: "groq/llama-3.3-70b-versatile"
# (com GROQ_API_KEY), "openai/gpt-4o-mini" (OPENAI_API_KEY), etc.
LLM_MODEL=gemini/gemini-2.5-flash
EMBED_MODEL=gemini/gemini-embedding-001

# --- ChromaDB ---
CHROMA_PERSIST_PATH=

# --- RAG ---
CHUNK_SIZE=
CHUNK_OVERLAP=
SIMILARITY_THRESHOLD=
MAX_CHUNKS_RETRIEVED=

# --- API ---
API_SECRET_KEY=
API_PORT=

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Número do WhatsApp do bot, sem +, com DDI. Ex: 5531990899055.
# Usado pra montar o link wa.me/<numero> que o aluno clica pra iniciar
# a conversa (fluxo "aluno inicia" — evita detecção de spam pela Meta).
BOT_PHONE_NUMBER=

# --- Mongo da Evolution API (usado para resolver LID via ACKs de entrega) ---
EVOLUTION_MONGO_URI=
EVOLUTION_MONGO_DB=