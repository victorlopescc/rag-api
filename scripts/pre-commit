#!/usr/bin/env sh
# Pre-commit hook — roda a suite de testes antes de cada commit.
# Instale copiando para .git/hooks/pre-commit (veja README).
#
# Para pular temporariamente: git commit --no-verify

set -e

echo "→ Rodando pytest antes do commit..."
cd "$(git rev-parse --show-toplevel)/backend"

# Usa o Python do venv se existir, senão o do PATH.
if [ -x "../.venv/Scripts/python.exe" ]; then
  PY="../.venv/Scripts/python.exe"
elif [ -x "../.venv/bin/python" ]; then
  PY="../.venv/bin/python"
else
  PY="python"
fi

"$PY" -m pytest -q tests/

echo "✓ Testes OK — prosseguindo com o commit"
